<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Pixelate.Net.Avalonia.ViewModels"
        xmlns:controls="using:Pixelate.Net.Avalonia.Controls"
        x:Class="Pixelate.Net.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="拼豆像素画生成器 v1.0.55"
        Width="1280" Height="960"
        MinWidth="1080" MinHeight="960"
        WindowStartupLocation="CenterScreen"
        Icon="avares://Pixelate.Net-Avalonia/Res/icon.ico">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    </Window.KeyBindings>

    <Window.Styles>
        <!-- 状态按钮（RadioButton 实现：同组互斥，已选中不会被点击取消）：按下（选中）时蓝色背景白字，弹起（未选中）时浅灰背景深色字 -->
        <Style Selector="RadioButton.stateButton">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style Selector="RadioButton.stateButton:not(:checked)">
            <Setter Property="Background" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="#333333" />
            <Setter Property="BorderBrush" Value="#BDBDBD" />
        </Style>
        <Style Selector="RadioButton.stateButton:not(:checked):pointerover">
            <Setter Property="Background" Value="#D0D0D0" />
        </Style>
        <Style Selector="RadioButton.stateButton:checked">
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="#1565C0" />
        </Style>
        <Style Selector="RadioButton.stateButton:checked:pointerover">
            <Setter Property="Background" Value="#1E88E5" />
        </Style>
        <Style Selector="RadioButton.stateButton:checked:pressed">
            <Setter Property="Background" Value="#1565C0" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="3">

        <!-- 主区域：左 | 右 -->
        <Grid Grid.Row="0" ColumnDefinitions="320,4,*" Margin="0,0,0,4">

            <!-- 左列：正常视图 / 像素编辑面板 -->
            <Grid Grid.Column="0">
              <Grid RowDefinitions="320,4,*" IsVisible="{Binding IsNormalView}">

                <!-- 上：选择图片按钮 + 原图 + 编辑按钮 -->
                <Grid Grid.Row="0" RowDefinitions="Auto,*,Auto">
                    <Button Grid.Row="0"
                            Content="选择图片"
                            Command="{Binding PickImageCommand}"
                            IsEnabled="{Binding !IsEditing}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="16,6"
                            Margin="0,0,0,4">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#2196F3" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#42A5F5" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1976D2" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                        </Button.Resources>
                    </Button>
                    <Border Grid.Row="1"
                            Background="#F0F0F0"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Padding="6">
                        <controls:ImageSelectionControl
                            Source="{Binding OriginalBitmap}"
                            Selection="{Binding Selection, Mode=TwoWay}"
                            IsEditing="{Binding IsEditing}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
                    </Border>

                    <!-- 编辑/取消/应用按钮 -->
                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Button Content="编辑"
                                Command="{Binding EditCommand}"
                                IsVisible="{Binding !IsEditing}"
                                Classes="btn-edit"
                                HorizontalAlignment="Center"
                                Padding="24,6">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#4CAF50" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5DBD5D" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3D9140" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                            </Button.Resources>
                        </Button>
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding IsEditing}"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Button Content="取消"
                                    Command="{Binding CancelCommand}"
                                    Classes="btn-cancel"
                                    Padding="24,6">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#FF6B6B" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8585" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E04848" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                </Button.Resources>
                            </Button>
                            <Button Content="应用"
                                    Command="{Binding ApplyCommand}"
                                    Classes="btn-apply"
                                    Padding="24,6">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 下：参数设置 -->
                <Grid Grid.Row="2" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="参数设置"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4" />
                    <Border Grid.Row="1"
                            Background="#FAFAFA"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="4"
                            IsEnabled="{Binding !IsEditing}">
                        <Grid RowDefinitions="*,Auto">
                            <StackPanel Grid.Row="0" VerticalAlignment="Top">
                                <TextBlock Text="处理模式" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Modes}"
                                          SelectedItem="{Binding SelectedMode}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProcessModeOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="底板尺寸" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding BoardSizes}"
                                          SelectedItem="{Binding SelectedBoardSize}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,4">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BoardSizeOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <CheckBox Content="多板拼接"
                                          IsChecked="{Binding UseMultiBoard}"
                                          Margin="0,0,0,8" />

                                <TextBlock Text="分割数量" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding AvailableSplitSizes}"
                                          SelectedItem="{Binding SelectedSplitSize}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,4">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SplitSizeOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <NumericUpDown Minimum="1"
                                               Maximum="{Binding CustomSplitsMax}"
                                               Value="{Binding CustomSplits}"
                                               FormatString="0"
                                               IsVisible="{Binding IsCustomSplitSize}"
                                               Margin="0,0,0,14" />

                                <TextBlock Text="分割方向" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding SplitDirections}"
                                          SelectedItem="{Binding SelectedSplitDirection}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SplitDirectionOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="色卡" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Brands}"
                                          SelectedItem="{Binding SelectedBrand}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BeadBrandOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="显示模式" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding DisplayModes}"
                                          SelectedItem="{Binding SelectedDisplayMode}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DisplayModeOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Grid Grid.Row="1" ColumnDefinitions="*,8,*,8,*">
                                <Button Grid.Column="0"
                                        Content="编辑像素"
                                        Command="{Binding EditPixelsCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="14,16">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground" Color="#4CAF50" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5DBD5D" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3D9140" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    </Button.Resources>
                                </Button>
                                <Button Grid.Column="2"
                                        Content="删除像素"
                                        Command="{Binding DeletePixelsCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="14,16">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground" Color="#FF9800" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    </Button.Resources>
                                </Button>
                                <Button Grid.Column="4"
                                        Content="剔除噪点"
                                        Command="{Binding RemoveNoiseCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="14,16">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground" Color="#2196F3" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#42A5F5" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1976D2" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
              </Grid>

              <!-- 像素编辑面板 -->
              <Grid RowDefinitions="Auto,Auto,*,Auto" IsVisible="{Binding IsPixelEditing}">
                  <!-- 顶部：当前色卡 -->
                  <TextBlock Grid.Row="0"
                             Text="{Binding SelectedBrand.DisplayName}"
                             FontWeight="SemiBold"
                             Margin="0,0,0,8"
                             VerticalAlignment="Center" />

                  <!-- 状态按钮：逐点修改 / 批量修改（同组互斥，撑满面板） -->
                  <Grid Grid.Row="1" ColumnDefinitions="*,8,*" Margin="0,0,0,8">
                      <RadioButton Grid.Column="0"
                                   Content="逐点修改"
                                   Classes="stateButton"
                                   GroupName="EditMode"
                                   IsChecked="{Binding IsPerPixelEdit, Mode=TwoWay}"
                                   HorizontalAlignment="Stretch" />
                      <RadioButton Grid.Column="2"
                                   Content="批量修改"
                                   Classes="stateButton"
                                   GroupName="EditMode"
                                   IsChecked="{Binding IsBatchEdit, Mode=TwoWay}"
                                   HorizontalAlignment="Stretch" />
                  </Grid>

                  <!-- 逐点修改：色卡颜色列表（单列） -->
                  <Border Grid.Row="2"
                          Background="#FAFAFA"
                          BorderBrush="#D0D0D0"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="6"
                          IsVisible="{Binding IsPerPixelEdit}">
                      <ListBox ItemsSource="{Binding EditColors}"
                               SelectedItem="{Binding SelectedEditColor, Mode=TwoWay}"
                               Background="Transparent"
                               BorderThickness="0">
                          <ListBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:PaletteColorItem">
                                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="2">
                                      <Border Width="18" Height="18"
                                              Background="{Binding Brush}"
                                              BorderBrush="#C0C0C0"
                                              BorderThickness="1"
                                              CornerRadius="2" />
                                      <TextBlock Text="{Binding DisplayName}"
                                                 FontSize="12"
                                                 TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" />
                                  </StackPanel>
                              </DataTemplate>
                          </ListBox.ItemTemplate>
                          <ListBox.Styles>
                              <Style Selector="ListBoxItem">
                                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                  <Setter Property="Padding" Value="4,2" />
                              </Style>
                          </ListBox.Styles>
                      </ListBox>
                  </Border>

                  <!-- 批量修改：被替换颜色列表 + 目标颜色列表 -->
                  <Grid Grid.Row="2"
                        RowDefinitions="Auto,*,Auto,*"
                        IsVisible="{Binding IsBatchEdit}"
                        Margin="0,8,0,0">
                      <TextBlock Grid.Row="0"
                                 Text="选择被替换的颜色"
                                 FontSize="13"
                                 Margin="0,0,0,4" />
                      <Border Grid.Row="1"
                              Background="#FAFAFA"
                              BorderBrush="#D0D0D0"
                              BorderThickness="1"
                              CornerRadius="4"
                              Padding="4"
                              MinHeight="80">
                          <ListBox ItemsSource="{Binding BatchEditSourceColors}"
                                   SelectedItem="{Binding BatchEditSourceColor, Mode=TwoWay}"
                                   Background="Transparent"
                                   BorderThickness="0">
                              <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PaletteColorItem">
                                      <StackPanel Orientation="Horizontal" Spacing="6" Margin="2">
                                          <Border Width="18" Height="18"
                                                  Background="{Binding Brush}"
                                                  BorderBrush="#C0C0C0"
                                                  BorderThickness="1"
                                                  CornerRadius="2" />
                                          <TextBlock Text="{Binding DisplayName}"
                                                     FontSize="12"
                                                     TextTrimming="CharacterEllipsis"
                                                     VerticalAlignment="Center" />
                                      </StackPanel>
                                  </DataTemplate>
                              </ListBox.ItemTemplate>
                              <ListBox.Styles>
                                  <Style Selector="ListBoxItem">
                                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                      <Setter Property="Padding" Value="4,2" />
                                  </Style>
                              </ListBox.Styles>
                          </ListBox>
                      </Border>

                      <TextBlock Grid.Row="2"
                                 Text="选择新颜色"
                                 FontSize="13"
                                 Margin="0,8,0,4" />
                      <Border Grid.Row="3"
                              Background="#FAFAFA"
                              BorderBrush="#D0D0D0"
                              BorderThickness="1"
                              CornerRadius="4"
                              Padding="4">
                          <ListBox ItemsSource="{Binding BatchEditTargetColors}"
                                   SelectedItem="{Binding BatchEditTargetColor, Mode=TwoWay}"
                                   Background="Transparent"
                                   BorderThickness="0">
                              <ListBox.ItemTemplate>
                                  <DataTemplate x:DataType="vm:PaletteColorItem">
                                      <StackPanel Orientation="Horizontal" Spacing="6" Margin="2">
                                          <Border Width="18" Height="18"
                                                  Background="{Binding Brush}"
                                                  BorderBrush="#C0C0C0"
                                                  BorderThickness="1"
                                                  CornerRadius="2" />
                                          <TextBlock Text="{Binding DisplayName}"
                                                     FontSize="12"
                                                     TextTrimming="CharacterEllipsis"
                                                     VerticalAlignment="Center" />
                                      </StackPanel>
                                  </DataTemplate>
                              </ListBox.ItemTemplate>
                              <ListBox.Styles>
                                  <Style Selector="ListBoxItem">
                                      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                      <Setter Property="Padding" Value="4,2" />
                                  </Style>
                              </ListBox.Styles>
                          </ListBox>
                      </Border>
                  </Grid>

                  <!-- 底部：替换 / 取消 / 应用 -->
				  <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="0,6,0,0">
					  <Button Grid.Column="0"
                              Content="替换"
                              Command="{Binding ReplaceColorsCommand}"
                              IsVisible="{Binding IsBatchEdit}"
                              Padding="14,6">
						  <Button.Resources>
							  <SolidColorBrush x:Key="ButtonBackground" Color="#2196F3" />
							  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#42A5F5" />
							  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1976D2" />
							  <SolidColorBrush x:Key="ButtonForeground" Color="White" />
							  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
						  </Button.Resources>
					  </Button>
                      <StackPanel Grid.Column="2"
                                  Orientation="Horizontal"
                                  Spacing="8"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,0,0">
                          <Button Content="取消"
                                  Command="{Binding CancelEditPixelsCommand}"
                                  Padding="24,6">
                              <Button.Resources>
                                  <SolidColorBrush x:Key="ButtonBackground" Color="#FF6B6B" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8585" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E04848" />
                                  <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                              </Button.Resources>
                          </Button>
                          <Button Content="应用"
                                  Command="{Binding ApplyEditPixelsCommand}"
                                  Padding="24,6">
                              <Button.Resources>
                                  <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                  <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                              </Button.Resources>
                          </Button>
                      </StackPanel>
				  </Grid>
              </Grid>

              <!-- 像素删除面板 -->
              <Grid RowDefinitions="Auto,Auto,*,Auto" IsVisible="{Binding IsPixelDeleting}">
                  <!-- 顶部：当前色卡 -->
                  <TextBlock Grid.Row="0"
                             Text="{Binding SelectedBrand.DisplayName}"
                             FontWeight="SemiBold"
                             Margin="0,0,0,8"
                             VerticalAlignment="Center" />

                  <!-- 状态按钮：逐点删除 / 批量删除（同组互斥，撑满面板） -->
                  <Grid Grid.Row="1" ColumnDefinitions="*,8,*" Margin="0,0,0,8">
                      <RadioButton Grid.Column="0"
                                   Content="逐点删除"
                                   Classes="stateButton"
                                   GroupName="DeleteMode"
                                   IsChecked="{Binding IsPerPixelDelete, Mode=TwoWay}"
                                   HorizontalAlignment="Stretch" />
                      <RadioButton Grid.Column="2"
                                   Content="批量删除"
                                   Classes="stateButton"
                                   GroupName="DeleteMode"
                                   IsChecked="{Binding IsBatchDelete, Mode=TwoWay}"
                                   HorizontalAlignment="Stretch" />
                  </Grid>

                  <!-- 逐点删除：提示文本 -->
                  <Border Grid.Row="2"
                          Background="#FAFAFA"
                          BorderBrush="#D0D0D0"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="12"
                          IsVisible="{Binding IsPerPixelDelete}">
                      <TextBlock Text="点击右侧图像中的像素，即可将它删除"
                                 FontSize="13"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center" />
                  </Border>

                  <!-- 批量删除：颜色列表（第一行为取色项） -->
                  <Border Grid.Row="2"
                          Background="#FAFAFA"
                          BorderBrush="#D0D0D0"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="6"
                          IsVisible="{Binding IsBatchDelete}">
                      <ListBox ItemsSource="{Binding DeleteColors}"
                               SelectedItem="{Binding SelectedDeleteColor, Mode=TwoWay}"
                               Background="Transparent"
                               BorderThickness="0">
                          <ListBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:DeleteColorItem">
                                  <Grid ColumnDefinitions="Auto,*,Auto">
                                      <Border Grid.Column="0" Width="18" Height="18"
                                              Background="{Binding Brush}"
                                              BorderBrush="#C0C0C0"
                                              BorderThickness="1"
                                              CornerRadius="2"
                                              Margin="0,0,6,0" />
                                      <TextBlock Grid.Column="1"
                                                 Text="{Binding DisplayName}"
                                                 FontSize="12"
                                                 TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" />
                                      <TextBlock Grid.Column="2"
                                                 Text="{Binding Count}"
                                                 IsVisible="{Binding ShowCount}"
                                                 FontSize="12"
                                                 VerticalAlignment="Center"
                                                 Margin="8,0,3,0" />
                                  </Grid>
                              </DataTemplate>
                          </ListBox.ItemTemplate>
                          <ListBox.Styles>
                              <Style Selector="ListBoxItem">
                                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                  <Setter Property="Padding" Value="4,2" />
                              </Style>
                          </ListBox.Styles>
                      </ListBox>
                  </Border>

                  <!-- 底部：删除 + 取消/应用 -->
                  <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" Margin="0,6,0,0">
                      <Button Grid.Column="0"
                              Content="删除"
                              Command="{Binding DeleteColorCommand}"
                              IsVisible="{Binding IsBatchDelete}"
                              Padding="14,6">
                          <Button.Resources>
                              <SolidColorBrush x:Key="ButtonBackground" Color="#F44336" />
                              <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF5C5C" />
                              <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#D32F2F" />
                              <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                              <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                          </Button.Resources>
                      </Button>
                      <StackPanel Grid.Column="2"
                                  Orientation="Horizontal"
                                  Spacing="8">
                          <Button Content="取消"
                                  Command="{Binding CancelDeletePixelsCommand}"
                                  Padding="24,6">
                              <Button.Resources>
                                  <SolidColorBrush x:Key="ButtonBackground" Color="#FF6B6B" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8585" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E04848" />
                                  <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                              </Button.Resources>
                          </Button>
                          <Button Content="应用"
                                  Command="{Binding ApplyDeletePixelsCommand}"
                                  Padding="24,6">
                              <Button.Resources>
                                  <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                  <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                              </Button.Resources>
                          </Button>
                      </StackPanel>
                  </Grid>
              </Grid>
            </Grid>

            <!-- 右列：像素化结果 + 显示编码复选框 -->
            <Grid Grid.Column="2" RowDefinitions="*,Auto">
                <Border Grid.Row="0"
                        Background="#F0F0F0"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        Padding="6">
                    <controls:PixelGridControl PixelData="{Binding PixelatedData}"
                                               GridWidth="{Binding PixelatedWidth}"
                                               GridHeight="{Binding PixelatedHeight}"
                                               DisplayMode="{Binding SelectedDisplayMode.Value}"
                                               IsEditable="{Binding IsPixelInteractive}"
                                               IsEyedropping="{Binding IsEyedropping}"
                                               ShowCodes="{Binding ShowCodes}"
                                               ColorCodeMap="{Binding ColorCodeMap}"
                                               PixelClicked="PixelGridControl_PixelClicked"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch" />
                </Border>
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,6,0,0">
                    <CheckBox Grid.Column="0"
                              Content="显示颜色编码（豆图分辨较高时颜色编码或许不能正常显示，但不影响导出结果）"
                              IsChecked="{Binding ShowCodes}"
                              IsEnabled="{Binding CanShowCodes}"
                              VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Content="导出"
                                IsEnabled="{Binding CanExport}"
                                Padding="20,6">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuItem Header="PNG" Command="{Binding ExportCommand}" CommandParameter="PNG" />
                                    <MenuItem Header="JPG" Command="{Binding ExportCommand}" CommandParameter="JPG" />
                                    <MenuItem Header="SVG" Command="{Binding ExportCommand}" CommandParameter="SVG" />
                                    <MenuItem Header="PDF" Command="{Binding ExportCommand}" CommandParameter="PDF" />
                                </MenuFlyout>
                            </Button.Flyout>
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                            </Button.Resources>
                        </Button>
                        <Button Content="打印"
                                Command="{Binding PrintCommand}"
                                Padding="20,6">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#2196F3" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#42A5F5" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1976D2" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="1"
                BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0"
                Padding="0,0,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                    <TextBlock Text="{Binding OriginalInfo}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding OutputInfo}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding BoardInfo}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="{Binding BeadCount}" VerticalAlignment="Center" />
                        <Button Content="详情"
                                Command="{Binding ShowDetailsCommand}"
                                IsVisible="{Binding HasPixelatedData}"
                                Padding="10,2"
                                FontSize="11">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Command="{Binding OpenGithubCommand}"
                        Padding="4"
                        VerticalAlignment="Center"
                        ToolTip.Tip="GitHub 仓库">
                    <Button.Resources>
                        <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#EAEAEA" />
                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#D0D0D0" />
                        <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                    </Button.Resources>
                    <Image Source="avares://Pixelate.Net-Avalonia/Res/github.png"
                           Width="24" Height="24" />
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
