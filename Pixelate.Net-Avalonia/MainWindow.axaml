<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Pixelate.Net.Avalonia.ViewModels"
        xmlns:controls="using:Pixelate.Net.Avalonia.Controls"
        x:Class="Pixelate.Net.Avalonia.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="拼豆像素画生成器 v0.6.21"
        Width="1280" Height="960"
        MinWidth="1280" MinHeight="960"
        WindowStartupLocation="CenterScreen"
        Icon="avares://Pixelate.Net-Avalonia/Res/icon.ico">

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    </Window.KeyBindings>

    <Grid RowDefinitions="*,Auto" Margin="12">

        <!-- 主区域：左 | 右 -->
        <Grid Grid.Row="0" ColumnDefinitions="280,8,*" Margin="0,0,0,8">

            <!-- 左列：正常视图 / 像素编辑面板 -->
            <Grid Grid.Column="0">
              <Grid RowDefinitions="320,8,*" IsVisible="{Binding IsNormalView}">

                <!-- 上：选择图片按钮 + 原图 + 编辑按钮 -->
                <Grid Grid.Row="0" RowDefinitions="Auto,*,Auto">
                    <Button Grid.Row="0"
                            Content="选择图片"
                            Command="{Binding PickImageCommand}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Padding="16,6"
                            Margin="0,0,0,8">
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#2196F3" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#42A5F5" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1976D2" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                        </Button.Resources>
                    </Button>
                    <Border Grid.Row="1"
                            Background="#F0F0F0"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            Padding="6">
                        <controls:ImageSelectionControl
                            Source="{Binding OriginalBitmap}"
                            Selection="{Binding Selection, Mode=TwoWay}"
                            IsEditing="{Binding IsEditing}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />
                    </Border>

                    <!-- 编辑/取消/应用按钮 -->
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Button Content="编辑"
                                Command="{Binding EditCommand}"
                                IsVisible="{Binding !IsEditing}"
                                Classes="btn-edit"
                                HorizontalAlignment="Center"
                                Padding="24,6">
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#4CAF50" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5DBD5D" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3D9140" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                            </Button.Resources>
                        </Button>
                        <StackPanel Orientation="Horizontal"
                                    IsVisible="{Binding IsEditing}"
                                    HorizontalAlignment="Center"
                                    Spacing="8">
                            <Button Content="取消"
                                    Command="{Binding CancelCommand}"
                                    Classes="btn-cancel"
                                    Padding="24,6">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#FF6B6B" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8585" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E04848" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                </Button.Resources>
                            </Button>
                            <Button Content="应用"
                                    Command="{Binding ApplyCommand}"
                                    Classes="btn-apply"
                                    Padding="24,6">
                                <Button.Resources>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                    <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- 下：参数设置 -->
                <Grid Grid.Row="2" RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="参数设置"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <Border Grid.Row="1"
                            Background="#FAFAFA"
                            BorderBrush="#D0D0D0"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="14">
                        <Grid RowDefinitions="*,Auto">
                            <StackPanel Grid.Row="0" VerticalAlignment="Top">
                                <TextBlock Text="处理模式" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Modes}"
                                          SelectedItem="{Binding SelectedMode}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ProcessModeOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="横向分割数量" Margin="0,0,0,4" />
                                <NumericUpDown Minimum="1"
                                               Maximum="1024"
                                               Value="{Binding HorizontalSplits}"
                                               FormatString="0"
                                               Margin="0,0,0,14" />

                                <TextBlock Text="色卡" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding Brands}"
                                          SelectedItem="{Binding SelectedBrand}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BeadBrandOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

								<CheckBox Content="颜色抖动"
                                          IsChecked="{Binding UseDither}"
                                          Margin="0,0,0,14" />

                                <Grid ColumnDefinitions="Auto,15,*" Margin="0,0,0,14">
                                    <CheckBox Grid.Column="0"
                                              Content="手动调整阈值"
                                              IsChecked="{Binding UseManualThreshold}"
                                              IsEnabled="{Binding IsThresholdEnabled}"
                                              VerticalAlignment="Center" />
                                    <Slider Grid.Column="2"
                                            Minimum="0"
                                            Maximum="100"
                                            Value="{Binding ColorMergeThreshold}"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="False"
                                            IsEnabled="{Binding IsThresholdControlsEnabled}"
                                            VerticalAlignment="Center" />
                                </Grid>

                                <Grid ColumnDefinitions="*,8,Auto" Margin="0,0,0,14">
                                    <NumericUpDown Grid.Column="0"
                                                   Minimum="0"
                                                   Maximum="100"
                                                   Value="{Binding ColorMergeThreshold}"
                                                   FormatString="0"
                                                   IsEnabled="{Binding IsThresholdControlsEnabled}" />
                                    <Button Grid.Column="2"
                                            Content="重置"
                                            Command="{Binding ResetThresholdCommand}"
                                            IsEnabled="{Binding IsThresholdControlsEnabled}"
                                            Classes="btn-reset"
                                            Padding="14,6">
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                            <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                        </Button.Resources>
                                    </Button>
                                </Grid>

                                <TextBlock Text="显示模式" Margin="0,0,0,4" />
                                <ComboBox ItemsSource="{Binding DisplayModes}"
                                          SelectedItem="{Binding SelectedDisplayMode}"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,14">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="vm:DisplayModeOption">
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Grid Grid.Row="1" ColumnDefinitions="*,8,*">
                                <Button Grid.Column="0"
                                        Content="编辑像素"
                                        Command="{Binding EditPixelsCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="14,16">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground" Color="#4CAF50" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#5DBD5D" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3D9140" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    </Button.Resources>
                                </Button>
                                <Button Grid.Column="2"
                                        Content="删除像素"
                                        Command="{Binding DeletePixelsCommand}"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Padding="14,16">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackground" Color="#FF9800" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
              </Grid>

              <!-- 像素编辑面板 -->
              <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsPixelEditing}">
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding SelectedBrand.DisplayName}"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                      <ToggleButton Grid.Column="1"
                                    Content="取色"
                                    Classes="accent"
                                    IsChecked="{Binding IsEyedropping}"
                                    Padding="14,6" />
                  </Grid>
                  <Border Grid.Row="1"
                          Background="#FAFAFA"
                          BorderBrush="#D0D0D0"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="6">
                      <ListBox ItemsSource="{Binding EditColors}"
                               SelectedItem="{Binding SelectedEditColor, Mode=TwoWay}"
                               Background="Transparent"
                               BorderThickness="0">
                          <ListBox.ItemsPanel>
                              <ItemsPanelTemplate>
                                  <UniformGrid Columns="3" />
                              </ItemsPanelTemplate>
                          </ListBox.ItemsPanel>
                          <ListBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:PaletteColorItem">
                                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="2">
                                      <Border Width="18" Height="18"
                                              Background="{Binding Brush}"
                                              BorderBrush="#C0C0C0"
                                              BorderThickness="1"
                                              CornerRadius="2" />
                                      <TextBlock Text="{Binding DisplayName}"
                                                 FontSize="11"
                                                 TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" />
                                  </StackPanel>
                              </DataTemplate>
                          </ListBox.ItemTemplate>
                          <ListBox.Styles>
                              <Style Selector="ListBoxItem">
                                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                  <Setter Property="Padding" Value="4,2" />
                              </Style>
                          </ListBox.Styles>
                      </ListBox>
                  </Border>
                  <StackPanel Grid.Row="2"
                              Orientation="Horizontal"
                              Spacing="8"
                              HorizontalAlignment="Right"
                              Margin="0,8,0,0">
                      <Button Content="取消"
                              Command="{Binding CancelEditPixelsCommand}"
                              Padding="24,6">
                          <Button.Resources>
                              <SolidColorBrush x:Key="ButtonBackground" Color="#FF6B6B" />
                              <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8585" />
                              <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E04848" />
                              <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                              <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                          </Button.Resources>
                      </Button>
                      <Button Content="应用"
                              Command="{Binding ApplyEditPixelsCommand}"
                              Padding="24,6">
                          <Button.Resources>
                              <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                              <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                              <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                              <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                              <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                          </Button.Resources>
                      </Button>
                  </StackPanel>
              </Grid>

              <!-- 像素删除面板 -->
              <Grid RowDefinitions="Auto,*,Auto" IsVisible="{Binding IsPixelDeleting}">
                  <!-- 顶部：色卡模式 + 取色按钮 -->
                  <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                      <TextBlock Grid.Column="0"
                                 Text="{Binding SelectedBrand.DisplayName}"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                      <ToggleButton Grid.Column="1"
                                    Content="取色"
                                    Classes="accent"
                                    IsChecked="{Binding IsEyedropping}"
                                    Padding="14,6" />
                  </Grid>

                  <!-- 颜色列表 -->
                  <Border Grid.Row="1"
                          Background="#FAFAFA"
                          BorderBrush="#D0D0D0"
                          BorderThickness="1"
                          CornerRadius="4"
                          Padding="6">
                      <ListBox ItemsSource="{Binding DeleteColors}"
                               SelectedItem="{Binding SelectedDeleteColor, Mode=TwoWay}"
                               Background="Transparent"
                               BorderThickness="0">
                          <ListBox.ItemTemplate>
                              <DataTemplate x:DataType="vm:DeleteColorItem">
                                  <Grid ColumnDefinitions="Auto,*,Auto">
                                      <Border Grid.Column="0" Width="18" Height="18"
                                              Background="{Binding Brush}"
                                              BorderBrush="#C0C0C0"
                                              BorderThickness="1"
                                              CornerRadius="2"
                                              Margin="0,0,6,0" />
                                      <TextBlock Grid.Column="1"
                                                 Text="{Binding DisplayName}"
                                                 FontSize="12"
                                                 TextTrimming="CharacterEllipsis"
                                                 VerticalAlignment="Center" />
                                      <TextBlock Grid.Column="2"
                                                 Text="{Binding Count}"
                                                 FontSize="12"
                                                 VerticalAlignment="Center"
                                                 Margin="8,0,0,0" />
                                  </Grid>
                              </DataTemplate>
                          </ListBox.ItemTemplate>
                          <ListBox.Styles>
                              <Style Selector="ListBoxItem">
                                  <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                  <Setter Property="Padding" Value="4,2" />
                              </Style>
                          </ListBox.Styles>
                      </ListBox>
                  </Border>

                  <!-- 底部：删除 + 取消/应用 -->
                  <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                      <Button Grid.Column="0"
                              Content="删除"
                              Command="{Binding DeleteColorCommand}"
                              Padding="14,6">
                          <Button.Resources>
                              <SolidColorBrush x:Key="ButtonBackground" Color="#F44336" />
                              <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF5C5C" />
                              <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#D32F2F" />
                              <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                              <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                          </Button.Resources>
                      </Button>
                      <StackPanel Grid.Column="2"
                                  Orientation="Horizontal"
                                  Spacing="8">
                          <Button Content="取消"
                                  Command="{Binding CancelDeletePixelsCommand}"
                                  Padding="24,6">
                              <Button.Resources>
                                  <SolidColorBrush x:Key="ButtonBackground" Color="#FF6B6B" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF8585" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#E04848" />
                                  <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                              </Button.Resources>
                          </Button>
                          <Button Content="应用"
                                  Command="{Binding ApplyDeletePixelsCommand}"
                                  Padding="24,6">
                              <Button.Resources>
                                  <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                                  <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                                  <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                  <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                              </Button.Resources>
                          </Button>
                      </StackPanel>
                  </Grid>
              </Grid>
            </Grid>

            <!-- 右列：像素化结果 + 显示编码复选框 -->
            <Grid Grid.Column="2" RowDefinitions="*,Auto">
                <Border Grid.Row="0"
                        Background="#F0F0F0"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        Padding="6">
                    <controls:PixelGridControl PixelData="{Binding PixelatedData}"
                                               GridWidth="{Binding PixelatedWidth}"
                                               GridHeight="{Binding PixelatedHeight}"
                                               DisplayMode="{Binding SelectedDisplayMode.Value}"
                                               IsEditable="{Binding IsPixelInteractive}"
                                               IsEyedropping="{Binding IsEyedropping}"
                                               ShowCodes="{Binding ShowCodes}"
                                               ColorCodeMap="{Binding ColorCodeMap}"
                                               PixelClicked="PixelGridControl_PixelClicked"
                                               HorizontalAlignment="Stretch"
                                               VerticalAlignment="Stretch" />
                </Border>
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,6,0,0">
                    <CheckBox Grid.Column="0"
                              Content="显示颜色编码"
                              IsChecked="{Binding ShowCodes}"
                              IsEnabled="{Binding CanShowCodes}"
                              VerticalAlignment="Center" />
                    <Button Grid.Column="2"
                            Content="导出"
                            IsEnabled="{Binding CanExport}"
                            Padding="20,6"
                            VerticalAlignment="Center">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="PNG" Command="{Binding ExportCommand}" CommandParameter="PNG" />
                                <MenuItem Header="JPG" Command="{Binding ExportCommand}" CommandParameter="JPG" />
                                <MenuItem Header="SVG" Command="{Binding ExportCommand}" CommandParameter="SVG" />
                                <MenuItem Header="PDF" Command="{Binding ExportCommand}" CommandParameter="PDF" />
                            </MenuFlyout>
                        </Button.Flyout>
                        <Button.Resources>
                            <SolidColorBrush x:Key="ButtonBackground" Color="#FFA500" />
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFB733" />
                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#CC8400" />
                            <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="1"
                BorderBrush="#D0D0D0"
                BorderThickness="0,1,0,0"
                Padding="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="24">
                <TextBlock Text="{Binding OriginalInfo}" />
                <TextBlock Text="{Binding OutputInfo}" />
                <TextBlock Text="{Binding BeadCount}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
